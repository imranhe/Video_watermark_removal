# 开发模式配置 - 快速启动
NODE_ENV=development
PORT=3000

# 跳过真实数据库，使用内存存储
SKIP_DATABASE=true
SKIP_REDIS=true

# JWT 配置
JWT_SECRET=dev-secret-key-for-testing-only
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 跳过第三方服务
SKIP_WECHAT=true
SKIP_ALIYUN=true
SKIP_OSS=true

# 禁用速率限制（开发方便）
ENABLE_RATE_LIMITING=false

# CORS 允许所有来源
CORS_ORIGIN=*

# 上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600
