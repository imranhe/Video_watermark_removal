# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files
*.html text encoding=utf-8
*.css text encoding=utf-8
*.js text encoding=utf-8
*.ts text encoding=utf-8
*.json text encoding=utf-8
*.vue text encoding=utf-8
*.md text encoding=utf-8
*.yaml text encoding=utf-8
*.yml text encoding=utf-8
*.xml text encoding=utf-8
*.sql text encoding=utf-8
*.sh text encoding=utf-8
*.env text encoding=utf-8
*.example text encoding=utf-8

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.pyc binary
*.pdf binary
