# 服务器配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=video_remover

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your_jwt_secret_here_make_it_very_long_and_secure
JWT_EXPIRES_IN=7d

# 阿里云配置
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_REGION=cn-hangzhou
ALIYUN_INPUT_BUCKET=your_input_bucket_name
ALIYUN_OUTPUT_BUCKET=your_output_bucket_name

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=314572800
CHUNK_SIZE=2097152

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# 日志配置
LOG_LEVEL=debug
LOG_DIR=./logs

# 任务配置
TASK_TIMEOUT=600000
MAX_RETRY_COUNT=3
MAX_CONCURRENT_TASKS=10

# 微信小程序配置
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# 微信支付配置
WECHAT_MCH_ID=your_merchant_id
WECHAT_SERIAL_NO=your_serial_no
WECHAT_API_KEY=your_api_key
WECHAT_NOTIFY_URL=https://your-domain.com/v1/orders/callback/wechat
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PAY_PUBLIC_KEY_PATH=./certs/apiclient_cert.pem
